# ─── Telegram ────────────────────────────────────────────────────────────────

# Bot token from @BotFather (required)
TELEGRAM_BOT_TOKEN=123456789:AAAA-replace-with-your-actual-token

# Default Telegram chat / group ID for the system prompt channel (required)
TELEGRAM_TARGET_CHAT_ID=-1001234567890

# Message parse mode: HTML or Markdown (default: HTML)
TELEGRAM_MESSAGE_PARSE_MODE=HTML

# Webhook mode (default: false — uses long polling)
TELEGRAM_USE_WEBHOOK=false
PUBLIC_WEBHOOK_URL=https://your.public.host/webhook
# Required when TELEGRAM_USE_WEBHOOK=true — must be a strong random string
TELEGRAM_WEBHOOK_SECRET=replace-with-a-strong-random-string

# ─── Database ────────────────────────────────────────────────────────────────

# PostgreSQL connection string for local dev (required)
DATABASE_URL=postgresql+psycopg://postgres:yourpassword@localhost:5432/tg_prompt_api

# PostgreSQL connection string used inside the Docker container
# (host.docker.internal resolves to the host machine from within the container)
DATABASE_URL_FROM_CONTAINER=postgresql+psycopg://postgres:yourpassword@host.docker.internal:5432/tg_prompt_api

# ─── Security ────────────────────────────────────────────────────────────────

# HMAC key used to sign outbound callbacks (X-Signature header)
# Must be a strong, unique random string — never commit a real value here
CALLBACK_SIGNING_SECRET=replace-with-a-strong-random-string

# Optional API key authentication for all endpoints
# Set USE_AUTH=true to require an X-API-Key header on every request
USE_AUTH=false
API_KEY=replace-with-a-strong-random-api-key

# ─── Media ───────────────────────────────────────────────────────────────────

# Restrict media_path uploads to this directory (security: prevents path traversal)
# Leave unset to disable the media_path feature entirely
# MEDIA_ALLOWED_DIR=/app/media

# ─── Boot ────────────────────────────────────────────────────────────────────

# Delete prompts that never got a Telegram message_id on startup (default: true)
CLEAN_ON_BOOT=true

# ─── Channel Gateway ─────────────────────────────────────────────────────────

# Max retry attempts when forwarding messages to a callback URL (default: 3)
CHANNEL_CALLBACK_MAX_RETRIES=3

# Seconds to wait between retry attempts (default: 5)
CHANNEL_CALLBACK_RETRY_DELAY=5

# Message sent to the Telegram channel when all callback retries are exhausted
CHANNEL_OFFLINE_NOTIFICATION=Assistant offline, could not deliver message.
