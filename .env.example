# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC
TELEGRAM_TARGET_CHAT_ID=-1001234567890
TELEGRAM_MESSAGE_PARSE_MODE=HTML
TELEGRAM_USE_WEBHOOK=false
PUBLIC_WEBHOOK_URL=https://your.host
TELEGRAM_WEBHOOK_SECRET=change-me

# Postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tg_prompt_api
DATABASE_URL_DOCKER=postgresql+psycopg://postgres:postgres@host.docker.internal:5432/tg_prompt_api

# Callbacks (sign outbound)
CALLBACK_SIGNING_SECRET=super-secret

# Boot
CLEAN_ON_BOOT=true
